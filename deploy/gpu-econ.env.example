# Required to enable email alert delivery.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=alerts@example.com

# Optional authentication and transport settings.
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Required before public clients may create email or webhook deliveries.
ALERT_DELIVERY_TOKEN=replace-with-a-long-random-value
